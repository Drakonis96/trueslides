# ─── TrueSlides Environment Variables ───
#
# Copy this file to .env.local and fill in the required values.
# NEVER commit .env.local to version control.

# ── Required ──

# Encryption key for storing API keys at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Optional: Image Source API Keys ──
# These can also be set per-session via the Settings panel in the UI.
# Setting them here makes them available as defaults.

# Unsplash API access key (https://unsplash.com/developers)
# UNSPLASH_ACCESS_KEY=

# Pexels API key (https://www.pexels.com/api/)
# PEXELS_API_KEY=

# Pixabay API key (https://pixabay.com/api/docs/)
# PIXABAY_API_KEY=

# Flickr API key (https://www.flickr.com/services/api/)
# FLICKR_API_KEY=

# Europeana API key (https://pro.europeana.eu/page/get-api)
# EUROPEANA_API_KEY=
